{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "labels": [
    "dependencies"
  ],
  "timezone": "Europe/Berlin",
  "commitMessagePrefix": "fix({{#if packageName}}{{packageName}}{{else}}{{manager}}{{/if}}):",
  "minimumReleaseAge": "7 days",
  "vulnerabilityAlerts": {
    "minimumReleaseAge": "3 days"
  },
  "platformAutomerge": false,
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Terraform module upgrades should bump version, chore doesn't imply a version bump",
      "matchCategories": ["terraform"],
      "semanticCommitType": "{{#if (equals updateType 'patch')}}fix{{else}}feat{{/if}}"
    },
    {
      "description": "Updates for Terragrunt",
      "matchManagers": ["terragrunt-version"],
      "matchNewValue": "1.0.0",
      "automerge": true,
      "dependencyDashboardApproval": false
    },
    {
      "description": "Only update upper-bound constraints for Terraform providers to protect the lockfile, forcing 'tf init -upgrade' to stick strictly to the max version approved by Renovate which follows minReleaseAge rather than fetching the latest registry version",
      "matchManagers": ["terraform"],
      "matchDepTypes": ["required_provider"],
      "rangeStrategy": "replace"
    }
  ]
}
